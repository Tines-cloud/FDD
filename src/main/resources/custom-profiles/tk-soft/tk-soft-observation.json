  "differential": {
    "element": [
      {
        "id": "Observation",
        "path": "Observation",
        "constraint": [
          {
            "key": "tk-obs-1",
            "severity": "error",
            "human": "Observation must have a value or a dataAbsentReason",
            "expression": "value.exists() or dataAbsentReason.exists()"
          },
          {
            "key": "tk-obs-2",
            "severity": "error",
            "human": "Vital signs must have a numeric value",
            "expression": "category.coding.where(code='vital-signs').exists() implies value.ofType(Quantity).exists()"
          }
        ]
      },
      {
        "id": "Observation.extension",
        "path": "Observation.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Observation.extension:deviceUsed",
        "path": "Observation.extension",
        "sliceName": "deviceUsed",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/device-used"
            ]
          }
        ],
        "mustSupport": true
      },
      {
