        "id": "Procedure",
        "path": "Procedure",
        "constraint": [
          {
            "key": "tk-proc-1",
            "severity": "error",
            "human": "Completed procedures must have a performed date",
            "expression": "status = 'completed' implies performed.exists()"
          },
          {
            "key": "tk-proc-2",
            "severity": "warning",
            "human": "Procedures should reference a performer or an asserter",
            "expression": "performer.exists() or asserter.exists()"
