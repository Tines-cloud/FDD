{
  "resourceType": "StructureDefinition",
  "id": "tk-soft-patient",
  "url": "https://tk-soft.example.com/fhir/StructureDefinition/Patient",
  "name": "TkSoftPatient",
  "title": "TK-Soft Patient Profile",
  "status": "active",
  "description": "TK-Soft custom Patient profile for EHR demographic management with strict demographic constraints, identifier slicing, and structured name and address requirements.",
  "version": "1.0.0",
  "experimental": false,
  "date": "2026-02-28",
  "publisher": "TK-Soft Healthcare",
  "contact": [
    {
      "name": "TK-Soft Healthcare",
      "telecom": [
        {
          "system": "url",
          "value": "https://tk-soft.example.com"
        }
      ]
    }
  ],
  "jurisdiction": [
    {
      "coding": [
        {
          "system": "urn:iso:std:iso:3166",
          "code": "LK",
          "display": "Sri Lanka"
        }
      ]
    }
  ],
  "copyright": "Copyright (c) 2026 TK-Soft Healthcare. All rights reserved.",
  "mapping": [
    {
      "identity": "rim",
      "uri": "http://hl7.org/v3",
      "name": "RIM Mapping"
    },
    {
      "identity": "w5",
      "uri": "http://hl7.org/fhir/fivews",
      "name": "FiveWs Pattern Mapping"
    },
    {
      "identity": "cda",
      "uri": "http://hl7.org/v3/cda",
      "name": "CDA (R2)"
    },
    {
      "identity": "v2",
      "uri": "http://hl7.org/v2",
      "name": "HL7 V2 Mapping"
    }
  ],
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Patient",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Patient",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Patient",
        "path": "Patient",
        "short": "TK-Soft Patient resource",
        "constraint": [
          {
            "key": "tk-pat-1",
            "severity": "error",
            "human": "Patient must have at least a family name or a given name",
            "expression": "name.exists() implies (name.family.exists() or name.given.exists())"
          },
          {
            "key": "tk-pat-2",
            "severity": "warning",
            "human": "Active patients should have at least one telecom",
            "expression": "active.where($this = true).exists() implies telecom.exists()"
          }
        ]
      },
      {
        "id": "Patient.extension",
        "path": "Patient.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Patient.extension:employeeId",
        "path": "Patient.extension",
        "sliceName": "employeeId",
        "short": "Employee ID for staff-patients",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/patient-employee-id"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Patient.extension:preferredLanguage",
        "path": "Patient.extension",
        "sliceName": "preferredLanguage",
        "short": "Preferred language for communication",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/patient-preferred-language"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Patient.extension:ethnicGroup",
        "path": "Patient.extension",
        "sliceName": "ethnicGroup",
        "short": "Ethnic group classification",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/patient-ethnic-group"
            ]
          }
        ]
      },
      {
        "id": "Patient.identifier",
        "path": "Patient.identifier",
        "short": "Patient identifier (required)",
        "min": 1,
        "mustSupport": true,
        "slicing": {
          "discriminator": [
            {
              "type": "pattern",
              "path": "type"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Patient.identifier:mrn",
        "path": "Patient.identifier",
        "sliceName": "mrn",
        "short": "Medical Record Number",
        "min": 1,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:mrn.type",
        "path": "Patient.identifier.type",
        "min": 1,
        "patternCodeableConcept": {
          "coding": [
            {
              "system": "http://terminology.hl7.org/CodeSystem/v2-0203",
              "code": "MR"
            }
          ]
        }
      },
      {
        "id": "Patient.identifier:mrn.system",
        "path": "Patient.identifier.system",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:mrn.value",
        "path": "Patient.identifier.value",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:national",
        "path": "Patient.identifier",
        "sliceName": "national",
        "short": "National ID (NIC or Passport)",
        "min": 0,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:national.system",
        "path": "Patient.identifier.system",
        "min": 1
      },
      {
        "id": "Patient.identifier:national.value",
        "path": "Patient.identifier.value",
        "min": 1
      },
      {
        "id": "Patient.active",
        "path": "Patient.active",
        "mustSupport": true
      },
      {
        "id": "Patient.name",
        "path": "Patient.name",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.name.family",
        "path": "Patient.name.family",
        "mustSupport": true
      },
      {
        "id": "Patient.name.given",
        "path": "Patient.name.given",
        "mustSupport": true
      },
      {
        "id": "Patient.name.prefix",
        "path": "Patient.name.prefix",
        "mustSupport": true
      },
      {
        "id": "Patient.telecom",
        "path": "Patient.telecom",
        "min": 1,
        "max": "5",
        "mustSupport": true
      },
      {
        "id": "Patient.telecom.system",
        "path": "Patient.telecom.system",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/ValueSet/contact-point-system"
        }
      },
      {
        "id": "Patient.telecom.value",
        "path": "Patient.telecom.value",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.telecom.use",
        "path": "Patient.telecom.use",
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/ValueSet/contact-point-use"
        }
      },
      {
        "id": "Patient.gender",
        "path": "Patient.gender",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/ValueSet/administrative-gender"
        }
      },
      {
        "id": "Patient.birthDate",
        "path": "Patient.birthDate",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.deceased[x]",
        "path": "Patient.deceased[x]",
        "mustSupport": true
      },
      {
        "id": "Patient.address",
        "path": "Patient.address",
        "mustSupport": true
      },
      {
        "id": "Patient.address.line",
        "path": "Patient.address.line",
        "mustSupport": true
      },
      {
        "id": "Patient.address.city",
        "path": "Patient.address.city",
        "mustSupport": true
      },
      {
        "id": "Patient.address.state",
        "path": "Patient.address.state",
        "mustSupport": true
      },
      {
        "id": "Patient.address.postalCode",
        "path": "Patient.address.postalCode",
        "mustSupport": true
      },
      {
        "id": "Patient.address.country",
        "path": "Patient.address.country",
        "mustSupport": true
      },
      {
        "id": "Patient.maritalStatus",
        "path": "Patient.maritalStatus",
        "binding": {
          "strength": "extensible",
          "valueSet": "https://tk-soft.example.com/fhir/ValueSet/marital-status"
        }
      },
      {
        "id": "Patient.photo",
        "path": "Patient.photo",
        "max": "0"
      },
      {
        "id": "Patient.contact",
        "path": "Patient.contact"
      },
      {
        "id": "Patient.contact.relationship",
        "path": "Patient.contact.relationship",
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "https://tk-soft.example.com/fhir/ValueSet/contact-relationship"
        }
      },
      {
        "id": "Patient.contact.name",
        "path": "Patient.contact.name",
        "mustSupport": true
      },
      {
        "id": "Patient.contact.telecom",
        "path": "Patient.contact.telecom",
        "mustSupport": true
      },
      {
        "id": "Patient.communication",
        "path": "Patient.communication"
      },
      {
        "id": "Patient.communication.language",
        "path": "Patient.communication.language",
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "https://tk-soft.example.com/fhir/ValueSet/languages"
        }
      },
      {
        "id": "Patient.generalPractitioner",
        "path": "Patient.generalPractitioner",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/Practitioner"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Patient.managingOrganization",
        "path": "Patient.managingOrganization",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/Organization"
            ]
          }
        ],
        "mustSupport": true
      }
    ]
  }
}
