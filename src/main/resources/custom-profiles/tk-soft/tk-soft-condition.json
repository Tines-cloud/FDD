  "publisher": "TK-Soft Healthcare",
  "contact": [
    {
      "name": "TK-Soft Healthcare",
      "telecom": [
        {
          "system": "url",
          "value": "https://tk-soft.example.com"
        }
      ]
    }
  ],
  "jurisdiction": [
    {
      "coding": [
        {
          "system": "urn:iso:std:iso:3166",
          "code": "LK",
          "display": "Sri Lanka"
        }
      ]
    }
  ],
  "copyright": "Copyright (c) 2026 TK-Soft Healthcare. All rights reserved.",
  "mapping": [
    {
      "identity": "rim",
      "uri": "http://hl7.org/v3",
      "name": "RIM Mapping"
    },
    {
      "identity": "w5",
      "uri": "http://hl7.org/fhir/fivews",
      "name": "FiveWs Pattern Mapping"
    },
    {
      "identity": "sct-concept",
      "uri": "http://snomed.info/conceptdomain",
      "name": "SNOMED CT Concept Domain Binding"
    },
    {
      "identity": "v2",
      "uri": "http://hl7.org/v2",
      "name": "HL7 V2 Mapping"
    }
  ],
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Condition",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Condition",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Condition",
        "path": "Condition",
        "constraint": [
          {
            "key": "tk-con-1",
            "severity": "error",
            "human": "Condition must have either a code or a category",
            "expression": "code.exists() or category.exists()"
          },
          {
            "key": "tk-con-2",
            "severity": "warning",
            "human": "Resolved conditions should have an abatement date",
            "expression": "clinicalStatus.coding.where(code='resolved').exists() implies abatement.exists()"
          }
        ]
      },
      {
        "id": "Condition.extension",
        "path": "Condition.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Condition.extension:conditionDuration",
        "path": "Condition.extension",
        "sliceName": "conditionDuration",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/condition-duration"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.extension:conditionSeverityScore",
        "path": "Condition.extension",
        "sliceName": "conditionSeverityScore",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/condition-severity-score"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.extension:diagnosisGroup",
        "path": "Condition.extension",
        "sliceName": "diagnosisGroup",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/diagnosis-group"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.clinicalStatus",
        "path": "Condition.clinicalStatus",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/ValueSet/condition-clinical"
        }
      },
      {
        "id": "Condition.verificationStatus",
        "path": "Condition.verificationStatus",
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/ValueSet/condition-ver-status"
        }
      },
      {
        "id": "Condition.category",
        "path": "Condition.category",
        "min": 1,
        "mustSupport": true,
        "slicing": {
          "discriminator": [
            {
              "type": "pattern",
              "path": "$this"
            }
          ],
          "rules": "open"
        }
      },
      {
        "id": "Condition.category:problemList",
        "path": "Condition.category",
        "sliceName": "problemList",
        "min": 0,
        "max": "1",
        "patternCodeableConcept": {
          "coding": [
            {
              "system": "http://terminology.hl7.org/CodeSystem/condition-category",
              "code": "problem-list-item"
            }
          ]
        },
        "mustSupport": true
      },
      {
        "id": "Condition.category:encounterDiagnosis",
        "path": "Condition.category",
        "sliceName": "encounterDiagnosis",
        "min": 0,
        "max": "1",
        "patternCodeableConcept": {
          "coding": [
            {
              "system": "http://terminology.hl7.org/CodeSystem/condition-category",
              "code": "encounter-diagnosis"
            }
          ]
        },
        "mustSupport": true
      },
      {
        "id": "Condition.severity",
        "path": "Condition.severity",
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/ValueSet/condition-severity"
        }
      },
      {
        "id": "Condition.code",
        "path": "Condition.code",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "https://tk-soft.example.com/fhir/ValueSet/condition-code"
        }
      },
      {
        "id": "Condition.code.coding",
        "path": "Condition.code.coding",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Condition.code.coding.system",
        "path": "Condition.code.coding.system",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Condition.code.coding.code",
        "path": "Condition.code.coding.code",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Condition.bodySite",
        "path": "Condition.bodySite",
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/ValueSet/body-site"
        }
      },
      {
        "id": "Condition.subject",
        "path": "Condition.subject",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/Patient"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.encounter",
        "path": "Condition.encounter",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/Encounter"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.onset[x]",
        "path": "Condition.onset[x]",
        "type": [
          {
            "code": "dateTime"
          },
          {
            "code": "Age"
          },
          {
            "code": "Period"
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.abatement[x]",
        "path": "Condition.abatement[x]",
        "type": [
          {
            "code": "dateTime"
          },
          {
            "code": "Age"
          },
          {
            "code": "Period"
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.recordedDate",
        "path": "Condition.recordedDate",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Condition.recorder",
        "path": "Condition.recorder",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://tk-soft.example.com/fhir/StructureDefinition/Practitioner"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.note",
        "path": "Condition.note",
        "mustSupport": true
      }
    ]
  }
}
