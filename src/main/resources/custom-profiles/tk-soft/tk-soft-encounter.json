  "differential": {
    "element": [
      {
        "id": "Encounter",
        "path": "Encounter",
        "constraint": [
          {
            "key": "tk-enc-1",
            "severity": "error",
            "human": "Encounter must have a period when status is finished",
            "expression": "status = 'finished' implies period.exists()"
          },
          {
            "key": "tk-enc-2",
            "severity": "warning",
            "human": "Inpatient encounters should have hospitalization details",
            "expression": "class.code = 'IMP' implies hospitalization.exists()"
          }
        ]
      },
