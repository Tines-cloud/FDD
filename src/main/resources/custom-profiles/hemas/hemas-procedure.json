      {
        "id": "Procedure",
        "path": "Procedure",
        "constraint": [
          {
            "key": "hemas-proc-1",
            "severity": "error",
            "human": "Completed procedures must have a performed period",
            "expression": "status = 'completed' implies performed.exists()"
          },
          {
            "key": "hemas-proc-2",
            "severity": "error",
            "human": "Surgical procedures must have a location",
            "expression": "category.coding.where(code='387713003').exists() implies location.exists()"
          },
          {
            "key": "hemas-proc-3",
            "severity": "warning",
            "human": "Procedures should have at least one performer",
            "expression": "performer.exists()"
          }
        ]
      },
