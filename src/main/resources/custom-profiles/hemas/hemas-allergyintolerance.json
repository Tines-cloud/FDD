          {
            "key": "hemas-ai-1",
            "severity": "error",
            "human": "Active allergies must have a code",
            "expression": "clinicalStatus.coding.where(code='active').exists() implies code.exists()"
          },
          {
            "key": "hemas-ai-2",
            "severity": "warning",
            "human": "High criticality allergies should have at least one reaction",
            "expression": "criticality = 'high' implies reaction.exists()"
