{
  "resourceType": "StructureDefinition",
  "id": "hemas-medicationrequest",
  "url": "https://hemas.example.com/fhir/StructureDefinition/MedicationRequest",
  "version": "1.0.0",
  "name": "HemasMedicationRequest",
  "title": "Hemas MedicationRequest Profile",
  "status": "active",
  "date": "2025-01-15",
  "publisher": "Hemas Holdings",
  "description": "Hemas hospital group MedicationRequest profile requiring encounter linkage, pharmacy verification, and single-category classification for hospital formulary management.",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "MedicationRequest",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/MedicationRequest",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "MedicationRequest",
        "path": "MedicationRequest",
        "short": "Hemas hospital medication request",
