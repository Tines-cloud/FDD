        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://hemas.example.com/fhir/StructureDefinition/practitioner-medical-council-id"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Practitioner.extension:specialistRegNo",
        "path": "Practitioner.extension",
        "sliceName": "specialistRegNo",
        "short": "Specialist registration number",
        "definition": "The practitioner's specialist registration number, if applicable.",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://hemas.example.com/fhir/StructureDefinition/practitioner-specialist-reg-no"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Practitioner.identifier",
        "path": "Practitioner.identifier",
        "short": "Practitioner identifiers (employee ID, NIC)",
