    "element": [
      {
        "id": "Encounter",
        "path": "Encounter",
        "constraint": [
          {
            "key": "hemas-enc-1",
            "severity": "error",
            "human": "Finished encounters must have an end date",
            "expression": "status = 'finished' implies period.end.exists()"
          },
          {
            "key": "hemas-enc-2",
            "severity": "warning",
            "human": "Emergency encounters should have a priority",
            "expression": "class.code = 'EMER' implies priority.exists()"
          },
          {
            "key": "hemas-enc-3",
            "severity": "error",
            "human": "Inpatient encounters must have a location",
            "expression": "class.code = 'IMP' implies location.exists()"
          }
        ]
      },
