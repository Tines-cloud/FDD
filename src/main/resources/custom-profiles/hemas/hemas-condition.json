  "differential": {
    "element": [
      {
        "id": "Condition",
        "path": "Condition",
        "constraint": [
          {
            "key": "hemas-con-1",
            "severity": "error",
            "human": "Condition must have a code with at least one coding",
            "expression": "code.coding.exists()"
          },
          {
            "key": "hemas-con-2",
            "severity": "warning",
            "human": "Confirmed conditions should have an onset",
            "expression": "verificationStatus.coding.where(code='confirmed').exists() implies onset.exists()"
          }
        ]
      },
      {
        "id": "Condition.extension",
        "path": "Condition.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Condition.extension:hospitalDepartment",
        "path": "Condition.extension",
        "sliceName": "hospitalDepartment",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://hemas.example.com/fhir/StructureDefinition/hospital-department"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.extension:icdBlock",
        "path": "Condition.extension",
        "sliceName": "icdBlock",
