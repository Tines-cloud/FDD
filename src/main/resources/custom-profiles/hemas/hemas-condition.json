      {
        "id": "Condition.code.coding",
        "path": "Condition.code.coding",
        "min": 1,
        "mustSupport": true,
        "slicing": {
          "discriminator": [
            {
              "type": "pattern",
              "path": "$this"
            }
          ],
          "rules": "open"
        }
      },
      {
        "id": "Condition.code.coding:icd10",
        "path": "Condition.code.coding",
        "sliceName": "icd10",
        "min": 1,
