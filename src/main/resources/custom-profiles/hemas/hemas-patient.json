      {
        "id": "Patient",
        "path": "Patient",
        "constraint": [
          {
            "key": "hemas-pat-1",
            "severity": "error",
            "human": "Patient must have at least one identifier with a system",
            "expression": "identifier.where(system.exists()).exists()"
          },
          {
            "key": "hemas-pat-2",
            "severity": "warning",
            "human": "Patient should have an emergency contact",
            "expression": "contact.exists()"
          }
        ]
      },
      {
