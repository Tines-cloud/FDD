          {
            "code": "Extension",
            "profile": [
              "https://hemas.example.com/fhir/StructureDefinition/insurance-provider"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Patient.identifier",
        "path": "Patient.identifier",
        "min": 1,
        "mustSupport": true,
        "slicing": {
          "discriminator": [
            {
              "type": "pattern",
              "path": "type"
            }
          ],
          "rules": "open"
        }
      },
      {
        "id": "Patient.identifier:hospitalId",
