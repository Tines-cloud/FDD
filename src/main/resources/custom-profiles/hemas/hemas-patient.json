        "path": "Patient.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Patient.extension:registrationDate",
        "path": "Patient.extension",
        "sliceName": "registrationDate",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://hemas.example.com/fhir/StructureDefinition/registration-date"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Patient.extension:vipStatus",
        "path": "Patient.extension",
        "sliceName": "vipStatus",
        "min": 0,
        "max": "1",
