        "path": "Observation",
        "constraint": [
          {
            "key": "hemas-obs-1",
            "severity": "error",
            "human": "Observation must have value or dataAbsentReason or component",
            "expression": "value.exists() or dataAbsentReason.exists() or component.exists()"
          },
          {
            "key": "hemas-obs-2",
            "severity": "warning",
            "human": "Lab results should have a specimen reference",
            "expression": "category.coding.where(code='laboratory').exists() implies specimen.exists()"
          }
        ]
