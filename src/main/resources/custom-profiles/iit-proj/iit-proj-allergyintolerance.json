            "key": "iit-ai-1",
            "severity": "error",
            "human": "Medication allergies must use MedDRA coding",
            "expression": "category.where(value='medication').exists() implies reaction.manifestation.coding.where(system='http://www.meddra.org').exists()"
          },
          {
            "key": "iit-ai-2",
            "severity": "warning",
            "human": "High criticality allergies should trigger SAE assessment",
            "expression": "criticality = 'high' implies extension.where(url='https://iit-proj.example.com/fhir/StructureDefinition/sae-assessment').exists()"
          },
          {
            "key": "iit-ai-3",
            "severity": "error",
            "human": "Must have at least one reaction recorded",
            "expression": "reaction.exists()"
          }
