{
  "resourceType": "StructureDefinition",
  "id": "iit-proj-condition",
  "url": "https://iit-proj.example.com/fhir/StructureDefinition/Condition",
  "name": "IitProjCondition",
  "title": "IIT Research Condition Profile",
  "status": "active",
  "version": "1.0.0",
  "experimental": false,
  "date": "2026-02-28",
  "publisher": "IIT-Project FHIR Team",
  "contact": [
    {
      "name": "IIT-Project FHIR Team",
      "telecom": [
        {
          "system": "url",
          "value": "https://iit-proj.example.com"
        }
      ]
    }
  ],
  "jurisdiction": [
    {
      "coding": [
        {
          "system": "urn:iso:std:iso:3166",
          "code": "IN",
          "display": "India"
        }
      ]
    }
  ],
  "copyright": "Copyright (c) 2026 IIT-Project FHIR Team. All rights reserved.",
  "mapping": [
    {
      "identity": "rim",
      "uri": "http://hl7.org/v3",
      "name": "RIM Mapping"
    },
    {
      "identity": "w5",
      "uri": "http://hl7.org/fhir/fivews",
      "name": "FiveWs Pattern Mapping"
    },
    {
      "identity": "sct-concept",
      "uri": "http://snomed.info/conceptdomain",
      "name": "SNOMED CT Concept Domain Binding"
    },
    {
      "identity": "v2",
      "uri": "http://hl7.org/v2",
      "name": "HL7 V2 Mapping"
    }
  ],
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Condition",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Condition",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Condition",
        "path": "Condition",
        "constraint": [
          {
            "key": "iit-con-1",
            "severity": "error",
            "human": "Research conditions must be coded with at least ICD-10 or SNOMED",
            "expression": "code.coding.where(system = 'http://hl7.org/fhir/sid/icd-10' or system = 'http://snomed.info/sct').exists()"
          },
          {
            "key": "iit-con-2",
            "severity": "error",
            "human": "Inclusion criteria conditions must be verified",
            "expression": "category.coding.where(code='inclusion-criteria').exists() implies verificationStatus.coding.where(code='confirmed').exists()"
          }
        ]
      },
      {
        "id": "Condition.extension",
        "path": "Condition.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Condition.extension:studyRelevance",
        "path": "Condition.extension",
        "sliceName": "studyRelevance",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/study-relevance"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.extension:protocolCriterion",
        "path": "Condition.extension",
        "sliceName": "protocolCriterion",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/protocol-criterion"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.extension:adverseEventLink",
        "path": "Condition.extension",
        "sliceName": "adverseEventLink",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/adverse-event-link"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.clinicalStatus",
        "path": "Condition.clinicalStatus",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/ValueSet/condition-clinical"
        }
      },
      {
        "id": "Condition.verificationStatus",
        "path": "Condition.verificationStatus",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/ValueSet/condition-ver-status"
        }
      },
      {
        "id": "Condition.category",
        "path": "Condition.category",
        "min": 1,
        "mustSupport": true,
        "slicing": {
          "discriminator": [
            {
              "type": "pattern",
              "path": "$this"
            }
          ],
          "rules": "open"
        }
      },
      {
        "id": "Condition.category:inclusionCriteria",
        "path": "Condition.category",
        "sliceName": "inclusionCriteria",
        "min": 0,
        "max": "1",
        "patternCodeableConcept": {
          "coding": [
            {
              "system": "https://iit-proj.example.com/fhir/CodeSystem/condition-category",
              "code": "inclusion-criteria"
            }
          ]
        },
        "mustSupport": true
      },
      {
        "id": "Condition.category:adverseEvent",
        "path": "Condition.category",
        "sliceName": "adverseEvent",
        "min": 0,
        "max": "1",
        "patternCodeableConcept": {
          "coding": [
            {
              "system": "https://iit-proj.example.com/fhir/CodeSystem/condition-category",
              "code": "adverse-event"
            }
          ]
        },
        "mustSupport": true
      },
      {
        "id": "Condition.category:comorbidity",
        "path": "Condition.category",
        "sliceName": "comorbidity",
        "min": 0,
        "max": "1",
        "patternCodeableConcept": {
          "coding": [
            {
              "system": "https://iit-proj.example.com/fhir/CodeSystem/condition-category",
              "code": "comorbidity"
            }
          ]
        },
        "mustSupport": true
      },
      {
        "id": "Condition.severity",
        "path": "Condition.severity",
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/ValueSet/condition-severity"
        }
      },
      {
        "id": "Condition.code",
        "path": "Condition.code",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Condition.code.coding",
        "path": "Condition.code.coding",
        "min": 1,
        "mustSupport": true,
        "slicing": {
          "discriminator": [
            {
              "type": "pattern",
              "path": "$this"
            }
          ],
          "rules": "open"
        }
      },
      {
        "id": "Condition.code.coding:icd10",
        "path": "Condition.code.coding",
        "sliceName": "icd10",
        "min": 0,
        "max": "1",
        "patternCoding": {
          "system": "http://hl7.org/fhir/sid/icd-10"
        },
        "mustSupport": true
      },
      {
        "id": "Condition.code.coding:snomed",
        "path": "Condition.code.coding",
        "sliceName": "snomed",
        "min": 0,
        "max": "1",
        "patternCoding": {
          "system": "http://snomed.info/sct"
        },
        "mustSupport": true
      },
      {
        "id": "Condition.code.coding:meddra",
        "path": "Condition.code.coding",
        "sliceName": "meddra",
        "min": 0,
        "max": "1",
        "patternCoding": {
          "system": "http://www.meddra.org"
        },
        "mustSupport": true
      },
      {
        "id": "Condition.bodySite",
        "path": "Condition.bodySite",
        "mustSupport": true
      },
      {
        "id": "Condition.subject",
        "path": "Condition.subject",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/Patient"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.encounter",
        "path": "Condition.encounter",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/Encounter"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.onset[x]",
        "path": "Condition.onset[x]",
        "min": 1,
        "type": [
          {
            "code": "dateTime"
          },
          {
            "code": "Age"
          },
          {
            "code": "Period"
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.abatement[x]",
        "path": "Condition.abatement[x]",
        "type": [
          {
            "code": "dateTime"
          },
          {
            "code": "Age"
          },
          {
            "code": "Period"
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Condition.recordedDate",
        "path": "Condition.recordedDate",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Condition.recorder",
        "path": "Condition.recorder",
        "max": "0",
        "comment": "Recorder blinded in research context"
      },
      {
        "id": "Condition.note",
        "path": "Condition.note",
        "mustSupport": true
      }
    ]
  }
}
