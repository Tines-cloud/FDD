{
  "resourceType": "StructureDefinition",
  "id": "iit-proj-location",
  "url": "https://iit-proj.example.com/fhir/StructureDefinition/Location",
  "name": "IitProjLocation",
  "title": "IIT-Proj Location Profile",
  "status": "active",
  "publisher": "IIT-Proj",
  "description": "Location profile for IIT-Proj research institution. ManagingOrganization, position, and alias are excluded (max=0). No telecom requirement. Includes site code and status extensions for research sites.",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Location",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Location",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Location.extension",
        "path": "Location.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Location.extension:siteCode",
        "path": "Location.extension",
        "sliceName": "siteCode",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/location-site-code"
            ]
          }
        ],
        "mustSupport": true,
        "short": "Unique research site code for the trial location"
      },
      {
        "id": "Location.extension:siteStatus",
        "path": "Location.extension",
        "sliceName": "siteStatus",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/location-site-status"
            ]
          }
        ],
        "mustSupport": true,
        "short": "Operational status of the research site"
      },
      {
        "id": "Location.name",
        "path": "Location.name",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Location.alias",
        "path": "Location.alias",
        "max": "0",
        "short": "Aliases excluded in research context"
      },
      {
        "id": "Location.mode",
        "path": "Location.mode",
        "mustSupport": true
      },
      {
        "id": "Location.type",
        "path": "Location.type",
        "mustSupport": true
      },
      {
        "id": "Location.telecom",
        "path": "Location.telecom",
        "mustSupport": true
      },
      {
        "id": "Location.address",
        "path": "Location.address",
        "mustSupport": true
      },
      {
        "id": "Location.physicalType",
        "path": "Location.physicalType",
        "mustSupport": true
      },
      {
        "id": "Location.position",
        "path": "Location.position",
        "max": "0",
        "short": "GPS coordinates excluded in research context"
      },
      {
        "id": "Location.managingOrganization",
        "path": "Location.managingOrganization",
        "max": "0",
        "short": "Managing organization excluded to prevent site identification"
      }
    ]
  }
}