            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "DiagnosticReport.extension:labAccessionNumber",
        "path": "DiagnosticReport.extension",
        "sliceName": "labAccessionNumber",
        "min": 0,
