{
  "resourceType": "StructureDefinition",
  "id": "iit-proj-procedure",
  "url": "https://iit-proj.example.com/fhir/StructureDefinition/Procedure",
  "name": "IitProjProcedure",
  "title": "IIT Research Procedure Profile",
  "status": "active",
  "version": "1.0.0",
  "experimental": false,
  "date": "2026-02-28",
  "publisher": "IIT-Project FHIR Team",
  "contact": [
    {
      "name": "IIT-Project FHIR Team",
      "telecom": [
        {
          "system": "url",
          "value": "https://iit-proj.example.com"
        }
      ]
    }
  ],
  "jurisdiction": [
    {
      "coding": [
        {
          "system": "urn:iso:std:iso:3166",
          "code": "IN",
          "display": "India"
        }
      ]
    }
  ],
  "copyright": "Copyright (c) 2026 IIT-Project FHIR Team. All rights reserved.",
  "mapping": [
    {
      "identity": "rim",
      "uri": "http://hl7.org/v3",
      "name": "RIM Mapping"
    },
    {
      "identity": "w5",
      "uri": "http://hl7.org/fhir/fivews",
      "name": "FiveWs Pattern Mapping"
    },
    {
      "identity": "v2",
      "uri": "http://hl7.org/v2",
      "name": "HL7 V2 Mapping"
    }
  ],
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Procedure",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Procedure",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Procedure",
        "path": "Procedure",
        "constraint": [
          {
            "key": "iit-proc-1",
            "severity": "error",
            "human": "Research procedures must be coded with SNOMED",
            "expression": "code.coding.where(system = 'http://snomed.info/sct').exists()"
          },
          {
            "key": "iit-proc-2",
            "severity": "error",
            "human": "Completed procedures must have a performed date",
            "expression": "status = 'completed' implies performed.exists()"
          },
          {
            "key": "iit-proc-3",
            "severity": "warning",
            "human": "Study procedures should reference the study encounter",
            "expression": "encounter.exists()"
          }
        ]
      },
      {
        "id": "Procedure.extension",
        "path": "Procedure.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Procedure.extension:studyProcedureType",
        "path": "Procedure.extension",
        "sliceName": "studyProcedureType",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/study-procedure-type"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Procedure.extension:protocolStep",
        "path": "Procedure.extension",
        "sliceName": "protocolStep",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/protocol-step"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Procedure.extension:adverseEventFlag",
        "path": "Procedure.extension",
        "sliceName": "adverseEventFlag",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/adverse-event-flag"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Procedure.identifier",
        "path": "Procedure.identifier",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Procedure.identifier.system",
        "path": "Procedure.identifier.system",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Procedure.identifier.value",
        "path": "Procedure.identifier.value",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Procedure.status",
        "path": "Procedure.status",
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/ValueSet/event-status"
        }
      },
      {
        "id": "Procedure.category",
        "path": "Procedure.category",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "https://iit-proj.example.com/fhir/ValueSet/procedure-category"
        }
      },
      {
        "id": "Procedure.code",
        "path": "Procedure.code",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Procedure.code.coding",
        "path": "Procedure.code.coding",
        "min": 1,
        "mustSupport": true,
        "slicing": {
          "discriminator": [
            {
              "type": "pattern",
              "path": "$this"
            }
          ],
          "rules": "open"
        }
      },
      {
        "id": "Procedure.code.coding:snomed",
        "path": "Procedure.code.coding",
        "sliceName": "snomed",
        "min": 1,
        "max": "1",
        "patternCoding": {
          "system": "http://snomed.info/sct"
        },
        "mustSupport": true
      },
      {
        "id": "Procedure.code.text",
        "path": "Procedure.code.text",
        "mustSupport": true
      },
      {
        "id": "Procedure.subject",
        "path": "Procedure.subject",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/Patient"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Procedure.encounter",
        "path": "Procedure.encounter",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/Encounter"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Procedure.performed[x]",
        "path": "Procedure.performed[x]",
        "min": 1,
        "type": [
          {
            "code": "dateTime"
          },
          {
            "code": "Period"
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Procedure.recorder",
        "path": "Procedure.recorder",
        "max": "0",
        "comment": "Recorder blinded in research context"
      },
      {
        "id": "Procedure.performer",
        "path": "Procedure.performer",
        "mustSupport": true
      },
      {
        "id": "Procedure.performer.function",
        "path": "Procedure.performer.function",
        "mustSupport": true
      },
      {
        "id": "Procedure.performer.actor",
        "path": "Procedure.performer.actor",
        "mustSupport": true
      },
      {
        "id": "Procedure.location",
        "path": "Procedure.location",
        "mustSupport": true
      },
      {
        "id": "Procedure.reasonCode",
        "path": "Procedure.reasonCode",
        "mustSupport": true
      },
      {
        "id": "Procedure.bodySite",
        "path": "Procedure.bodySite",
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/ValueSet/body-site"
        }
      },
      {
        "id": "Procedure.outcome",
        "path": "Procedure.outcome",
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "https://iit-proj.example.com/fhir/ValueSet/procedure-outcome"
        }
      },
      {
        "id": "Procedure.complication",
        "path": "Procedure.complication",
        "mustSupport": true
      },
      {
        "id": "Procedure.note",
        "path": "Procedure.note",
        "mustSupport": true
      }
    ]
  }
}
