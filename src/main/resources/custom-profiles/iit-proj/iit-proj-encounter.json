{
  "resourceType": "StructureDefinition",
  "id": "iit-proj-encounter",
  "url": "https://iit-proj.example.com/fhir/StructureDefinition/Encounter",
  "name": "IitProjEncounter",
  "title": "IIT Research Encounter Profile",
  "status": "active",
  "version": "1.0.0",
  "experimental": false,
  "date": "2026-02-28",
  "publisher": "IIT-Project FHIR Team",
  "contact": [
    {
      "name": "IIT-Project FHIR Team",
      "telecom": [
        {
          "system": "url",
          "value": "https://iit-proj.example.com"
        }
      ]
    }
  ],
  "jurisdiction": [
    {
      "coding": [
        {
          "system": "urn:iso:std:iso:3166",
          "code": "IN",
          "display": "India"
        }
      ]
    }
  ],
  "copyright": "Copyright (c) 2026 IIT-Project FHIR Team. All rights reserved.",
  "mapping": [
    {
      "identity": "rim",
      "uri": "http://hl7.org/v3",
      "name": "RIM Mapping"
    },
    {
      "identity": "w5",
      "uri": "http://hl7.org/fhir/fivews",
      "name": "FiveWs Pattern Mapping"
    },
    {
      "identity": "v2",
      "uri": "http://hl7.org/v2",
      "name": "HL7 V2 Mapping"
    }
  ],
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Encounter",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Encounter",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Encounter",
        "path": "Encounter",
        "constraint": [
          {
            "key": "iit-enc-1",
            "severity": "error",
            "human": "Research encounters must have a visit number",
            "expression": "identifier.where(type.coding.where(code='VN').exists()).exists()"
          },
          {
            "key": "iit-enc-2",
            "severity": "error",
            "human": "Encounter must reference a research patient",
            "expression": "subject.exists()"
          },
          {
            "key": "iit-enc-3",
            "severity": "warning",
            "human": "Completed visits should have a period with start and end",
            "expression": "status = 'finished' implies (period.start.exists() and period.end.exists())"
          }
        ]
      },
      {
        "id": "Encounter.extension",
        "path": "Encounter.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Encounter.extension:studyVisitNumber",
        "path": "Encounter.extension",
        "sliceName": "studyVisitNumber",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/study-visit-number"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Encounter.extension:protocolDeviation",
        "path": "Encounter.extension",
        "sliceName": "protocolDeviation",
        "min": 0,
        "max": "*",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/protocol-deviation"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Encounter.extension:visitWindow",
        "path": "Encounter.extension",
        "sliceName": "visitWindow",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/visit-window"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Encounter.identifier",
        "path": "Encounter.identifier",
        "min": 1,
        "mustSupport": true,
        "slicing": {
          "discriminator": [
            {
              "type": "pattern",
              "path": "type"
            }
          ],
          "rules": "open"
        }
      },
      {
        "id": "Encounter.identifier:visitId",
        "path": "Encounter.identifier",
        "sliceName": "visitId",
        "min": 1,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Encounter.identifier:visitId.type",
        "path": "Encounter.identifier.type",
        "min": 1,
        "patternCodeableConcept": {
          "coding": [
            {
              "system": "http://terminology.hl7.org/CodeSystem/v2-0203",
              "code": "VN"
            }
          ]
        },
        "mustSupport": true
      },
      {
        "id": "Encounter.identifier:visitId.system",
        "path": "Encounter.identifier.system",
        "min": 1,
        "fixedUri": "https://iit-proj.example.com/fhir/sid/visit-id",
        "mustSupport": true
      },
      {
        "id": "Encounter.identifier:visitId.value",
        "path": "Encounter.identifier.value",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Encounter.status",
        "path": "Encounter.status",
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/ValueSet/encounter-status"
        }
      },
      {
        "id": "Encounter.class",
        "path": "Encounter.class",
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "http://terminology.hl7.org/ValueSet/v3-ActEncounterCode"
        }
      },
      {
        "id": "Encounter.type",
        "path": "Encounter.type",
        "min": 1,
        "mustSupport": true,
        "slicing": {
          "discriminator": [
            {
              "type": "pattern",
              "path": "$this"
            }
          ],
          "rules": "open"
        }
      },
      {
        "id": "Encounter.type:studyVisit",
        "path": "Encounter.type",
        "sliceName": "studyVisit",
        "min": 1,
        "max": "1",
        "patternCodeableConcept": {
          "coding": [
            {
              "system": "https://iit-proj.example.com/fhir/CodeSystem/encounter-type",
              "code": "study-visit"
            }
          ]
        },
        "mustSupport": true
      },
      {
        "id": "Encounter.subject",
        "path": "Encounter.subject",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/Patient"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Encounter.participant",
        "path": "Encounter.participant",
        "mustSupport": true
      },
      {
        "id": "Encounter.participant.type",
        "path": "Encounter.participant.type",
        "mustSupport": true
      },
      {
        "id": "Encounter.participant.individual",
        "path": "Encounter.participant.individual",
        "mustSupport": true
      },
      {
        "id": "Encounter.period",
        "path": "Encounter.period",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Encounter.period.start",
        "path": "Encounter.period.start",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Encounter.reasonCode",
        "path": "Encounter.reasonCode",
        "mustSupport": true
      },
      {
        "id": "Encounter.diagnosis",
        "path": "Encounter.diagnosis",
        "mustSupport": true
      },
      {
        "id": "Encounter.hospitalization",
        "path": "Encounter.hospitalization",
        "max": "0",
        "comment": "Research visits are outpatient only"
      },
      {
        "id": "Encounter.location",
        "path": "Encounter.location",
        "mustSupport": true
      },
      {
        "id": "Encounter.location.location",
        "path": "Encounter.location.location",
        "mustSupport": true
      },
      {
        "id": "Encounter.serviceProvider",
        "path": "Encounter.serviceProvider",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://iit-proj.example.com/fhir/StructureDefinition/Organization"
            ]
          }
        ],
        "mustSupport": true
      }
    ]
  }
}
