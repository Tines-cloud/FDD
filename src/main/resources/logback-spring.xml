<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback configuration for FHIR Drift Doctor.

  Two appenders:
  1. CONSOLE - coloured output to stdout (same as Spring Boot defaults).
  2. FILE    - rolling file under logs/fdd.log with daily rotation and 30-day retention.

  Both appenders receive all log events at DEBUG level for com.example.fdd.
-->
<configuration>
    <!-- Import Spring Boot default console colours -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ==================== Console Appender ==================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== Rolling File Appender ==================== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/fdd.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{40} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Daily rollover; each file capped at 50 MB -->
            <fileNamePattern>logs/fdd-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <!-- Keep 30 days of history, with a total cap of 1 GB -->
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ==================== Logger Levels ==================== -->

    <!-- Application logs at DEBUG -->
    <logger name="com.example.fdd" level="DEBUG"/>

    <!-- HAPI-FHIR: keep quiet unless there's a problem -->
    <logger name="ca.uhn.fhir" level="WARN"/>

    <!-- Spring AI: INFO only -->
    <logger name="org.springframework.ai" level="INFO"/>

    <!-- Root logger: INFO to both console and file -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
